<Window x:Class="MCLauncher.WelcomeWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Minecraft Version Launcher!" 
        Height="550" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#161925"/>
        <SolidColorBrush x:Key="CardBg" Color="#202538"/>
        <SolidColorBrush x:Key="DarkBg" Color="#12141c"/>
        <SolidColorBrush x:Key="Border" Color="#2d3555"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8b95b8"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3b82f6"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#10b981"/>
        
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3b82f6" Offset="0"/>
            <GradientStop Color="#8b5cf6" Offset="1"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="ButtonShadow" Color="Black" BlurRadius="10" Opacity="0.3" Direction="270" ShadowDepth="4"/>
        <DropShadowEffect x:Key="CardShadow" Color="Black" BlurRadius="15" Opacity="0.2" Direction="270" ShadowDepth="5"/>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BigButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="30,15"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBg}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="30">
            <StackPanel HorizontalAlignment="Center">
                <Border CornerRadius="24" Width="80" Height="80" Margin="0,0,0,16" Background="{StaticResource AccentGradient}" Effect="{StaticResource CardShadow}">
                    <TextBlock Text="🎮" 
                               FontSize="48" 
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Welcome to Minecraft Version Launcher!" 
                           FontSize="26" 
                           FontWeight="ExtraBold" 
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Let's get you set up in just a few steps!" 
                           FontSize="15" 
                           Foreground="{StaticResource TextSecondary}" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Content Pages -->
        <Grid Grid.Row="1" Margin="40">
            <!-- Page 1: Welcome -->
            <StackPanel x:Name="Page1" Visibility="Visible">
                <TextBlock Text="What can this launcher do?" 
                           FontSize="22" 
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,30"/>

                <Border Background="{StaticResource CardBg}" 
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        CornerRadius="12" 
                        Padding="20"
                        Margin="0,0,0,15"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" 
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreen}"
                                   Margin="0,0,20,0"
                                   VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="Play different versions of Minecraft" 
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Switch between old and new versions anytime!" 
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,5,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBg}" 
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        CornerRadius="12" 
                        Padding="20"
                        Margin="0,0,0,15"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" 
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreen}"
                                   Margin="0,0,20,0"
                                   VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="Try Preview features early" 
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Test new Minecraft features before everyone else!" 
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,5,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBg}" 
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        CornerRadius="12" 
                        Padding="20"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" 
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreen}"
                                   Margin="0,0,20,0"
                                   VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="Your worlds stay safe" 
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Automatic backups keep your creations protected!" 
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,5,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Page 2: Requirements -->
            <StackPanel x:Name="Page2" Visibility="Collapsed">
                <TextBlock Text="Before we start..." 
                           FontSize="22" 
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,30"/>

                <Border Background="{StaticResource CardBg}" 
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        CornerRadius="12" 
                        Padding="25"
                        Margin="0,0,0,20"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="✓ You need these things:" 
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="1️⃣" FontSize="24" Margin="0,0,15,0"/>
                            <StackPanel>
                                <TextBlock Text="Minecraft from Microsoft Store" 
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="You must have Minecraft installed from the Store first!" 
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,3,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="2️⃣" FontSize="24" Margin="0,0,15,0"/>
                            <StackPanel>
                                <TextBlock Text="At least 2GB of free space" 
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Each version takes about 500MB" 
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,3,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="3️⃣" FontSize="24" Margin="0,0,15,0"/>
                            <StackPanel>
                                <TextBlock Text="Internet connection" 
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="To download versions" 
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,3,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#2a1b18" 
                        CornerRadius="8" 
                        Padding="20"
                        BorderBrush="#FF9800"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Top"/>
                        <TextBlock TextWrapping="Wrap" 
                                   FontSize="14"
                                   Foreground="{StaticResource TextPrimary}">
                            <Bold>Important:</Bold> If you don't have Minecraft from the Store yet, 
                            go install it first, then come back here!
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Page 3: Ready -->
            <StackPanel x:Name="Page3" Visibility="Collapsed">
                <TextBlock Text="You're all set! 🎉" 
                           FontSize="28" 
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,40,0,30"/>

                <Border Background="{StaticResource CardBg}" 
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        CornerRadius="12" 
                        Padding="30"
                        HorizontalAlignment="Center"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🎮" 
                                   FontSize="64" 
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>
                        
                        <TextBlock Text="Quick Start Guide:" 
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <StackPanel>
                            <TextBlock FontSize="14" 
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,0,0,10"
                                       TextWrapping="Wrap">
                                <Bold Foreground="{StaticResource AccentBlue}">1.</Bold> Go to the "Available" tab
                            </TextBlock>
                            <TextBlock FontSize="14" 
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,0,0,10"
                                       TextWrapping="Wrap">
                                <Bold Foreground="{StaticResource AccentBlue}">2.</Bold> Find a version with a ⭐ (recommended!)
                            </TextBlock>
                            <TextBlock FontSize="14" 
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,0,0,10"
                                       TextWrapping="Wrap">
                                <Bold Foreground="{StaticResource AccentBlue}">3.</Bold> Click "Download" and wait
                            </TextBlock>
                            <TextBlock FontSize="14" 
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,0,0,10"
                                       TextWrapping="Wrap">
                                <Bold Foreground="{StaticResource AccentBlue}">4.</Bold> Go to "My Versions" and click "PLAY"!
                            </TextBlock>
                        </StackPanel>

                        <Border Background="{StaticResource DarkBg}" 
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="1"
                                CornerRadius="8" 
                                Padding="15"
                                Margin="0,20,0,0">
                            <TextBlock TextWrapping="Wrap" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Center">
                                💡 Tip: If you need help, check the "Help" tab anytime!
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Footer Navigation -->
        <Border Grid.Row="2" Background="{StaticResource CardBg}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton" 
                        Grid.Column="0"
                        Content="← Back" 
                        Style="{StaticResource ModernButton}"
                        Background="{StaticResource Border}"
                        Foreground="{StaticResource TextPrimary}"
                        Click="Back_Click"
                        HorizontalAlignment="Left"
                        Visibility="Collapsed"/>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center">
                    <Ellipse x:Name="Dot1" Width="10" Height="10" Fill="{StaticResource AccentBlue}" Margin="6"/>
                    <Ellipse x:Name="Dot2" Width="10" Height="10" Fill="{StaticResource Border}" Margin="6"/>
                    <Ellipse x:Name="Dot3" Width="10" Height="10" Fill="{StaticResource Border}" Margin="6"/>
                </StackPanel>

                <Button x:Name="NextButton" 
                        Grid.Column="2"
                        Content="Next →" 
                        Style="{StaticResource BigButton}"
                        Click="Next_Click"
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
