<Window x:Class="MCLauncher.ModernSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" 
        Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <SolidColorBrush x:Key="MinecraftGreen" Color="#7CB342"/>
        <SolidColorBrush x:Key="MinecraftDarkGreen" Color="#558B2F"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#212121"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#757575"/>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource MinecraftGreen}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource MinecraftDarkGreen}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource MinecraftGreen}" Padding="20">
            <TextBlock Text="⚙️ Settings" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </Border>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20" 
                     PreviewMouseWheel="ScrollViewer_PreviewMouseWheel"
                     PreviewMouseDown="ScrollViewer_PreviewMouseDown"
                     PreviewMouseUp="ScrollViewer_PreviewMouseUp"
                     MouseMove="ScrollViewer_MouseMove">
            <StackPanel>
                <!-- Gameplay Settings -->
                <Border Style="{StaticResource SettingCard}">
                    <StackPanel>
                        <TextBlock Text="🎮 Gameplay" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,15"/>
                        
                        <CheckBox x:Name="ShowInstalledOnlyCheckbox"
                                  Content="Only show versions I have installed"
                                  FontSize="14"
                                  Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Hide versions you haven't downloaded yet" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="20,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Storage Settings -->
                <Border Style="{StaticResource SettingCard}">
                    <StackPanel>
                        <TextBlock Text="💾 Storage" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,15"/>
                        
                        <CheckBox x:Name="DeleteAfterInstallCheckbox"
                                  Content="Delete downloads after installing (saves space)"
                                  FontSize="14"
                                  Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Downloaded files will be removed after installation to save disk space" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="20,0,0,15"/>

                        <Button Content="📂 Open Launcher Folder" 
                                Style="{StaticResource ModernButton}"
                                Click="OpenDataFolder_Click"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Advanced Settings -->
                <Border Style="{StaticResource SettingCard}">
                    <StackPanel>
                        <TextBlock Text="🔧 Advanced" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,15"/>
                        
                        <CheckBox x:Name="ShowBetaTabCheckbox"
                                  Content="Show legacy Beta versions tab"
                                  FontSize="14"
                                  Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Shows old beta versions (rarely needed)" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="20,0,0,15"/>

                        <Button Content="🔄 Reset First-Time Warnings" 
                                Style="{StaticResource ModernButton}"
                                Click="ResetWarnings_Click"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,10"/>

                        <Button Content="📋 View Log File" 
                                Style="{StaticResource ModernButton}"
                                Click="OpenLogFile_Click"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Troubleshooting -->
                <Border Style="{StaticResource SettingCard}">
                    <StackPanel>
                        <TextBlock Text="🛠️ Troubleshooting" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,15"/>
                        
                        <Button Content="🗑️ Remove All Versions" 
                                Style="{StaticResource ModernButton}"
                                Background="#E53935"
                                Click="RemoveAllVersions_Click"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,10"/>
                        
                        <TextBlock Text="⚠️ This will remove all installed versions (your worlds stay safe)" 
                                   FontSize="12"
                                   Foreground="#E53935"
                                   Margin="20,0,0,15"/>

                        <Button Content="🔧 Fix Store Installation Issues" 
                                Style="{StaticResource ModernButton}"
                                Click="FixStoreIssues_Click"
                                HorizontalAlignment="Left"/>
                        
                        <TextBlock Text="Use this if you're having trouble installing from the Microsoft Store" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="20,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- About -->
                <Border Style="{StaticResource SettingCard}">
                    <StackPanel>
                        <TextBlock Text="ℹ️ About" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Minecraft Version Launcher" 
                                   FontSize="14"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,5"/>
                        
                        <TextBlock Text="Modern kid-friendly edition" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock Text="This launcher helps you play different versions of Minecraft!" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" 
                        Style="{StaticResource ModernButton}"
                        Background="#9E9E9E"
                        Click="Cancel_Click"
                        Margin="0,0,10,0"
                        MinWidth="100"/>
                <Button Content="Save" 
                        Style="{StaticResource ModernButton}"
                        Click="Save_Click"
                        MinWidth="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
